# Copy to `.env` and fill in your SMTP provider (Gmail app password, Mailgun, etc.)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Harithasuwa Orders <orders@harithasuwa.lk>"

# Inbox for contact form (should match site content `contact.recipientEmail`)
CONTACT_RECIPIENT_EMAIL=hello@harithasuwa.lk

# Optional
# CONTACT_EMAIL_SUBJECT=New Harithasuwa order
