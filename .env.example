# =============================================================================
# Harithasuwa environment variables
# =============================================================================
# Local:  copy this file to `.env` and fill in real values (`.env` is gitignored)
# Netlify: Site settings → Environment variables → add the SAME keys
#          (required for the contact form on production)
# =============================================================================

# --- SMTP (required for order emails) ---
# Examples:
#   Gmail:      smtp.gmail.com  / 587  / use an App Password (not your login password)
#   Brevo:      smtp-relay.brevo.com
#   Mailgun:    smtp.mailgun.org
#   Outlook:    smtp.office365.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Must be the same Gmail account that owns the App Password
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
# From must match SMTP_USER (Gmail rejects other addresses)
SMTP_FROM="Harithasuwa Orders <your-gmail@gmail.com>"

CONTACT_RECIPIENT_EMAIL=your-inbox@gmail.com

# Optional email subject line
# CONTACT_EMAIL_SUBJECT=New Harithasuwa order
